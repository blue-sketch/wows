{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    
    // NEW: Explicitly tell TypeScript where your custom types live
    "typeRoots": [
      "./node_modules/@types",
      "./src/server/types"
    ]
  },
  
  // CHANGED: Added "src/server" to the list so TS actually reads your backend code!
  "include": ["client/src", "src/shared", "src/server", "vite.config.ts"]
}
